{
  "name": "django-base-site",
  "description": "Django Base Site",
  "scripts": {
    "dev": "npx vite --config src/config/vite.config.mjs",
    "build": "npx vite build --config src/config/vite.config.mjs",
    "preview": "npx vite preview --config src/config/vite.config.mjs",
    "lint-sass": "npx stylelint --config src/config/stylelint.config.js ./src/scss/",
    "format-sass": "npx stylelint --config src/config/stylelint.config.js --fix 'src/**/*.{css,scss}'",
    "lint-js": "npx eslint --config src/config/eslint.config.js ./src/",
    "format-js": "npx eslint --config src/config/eslint.config.js --fix ./src/"
  },
  "devDependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "@eslint/js": "^10.0.0",
    "eslint": "^10.1.0",
    "globals": "^16.0.0",
    "sass": "~1.98",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "vite": "^8.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/epicserve/django-base-site.git"
  },
  "author": "Brent O'Connor",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/epicserve/django-base-site/issues"
  },
  "homepage": "https://github.com/epicserve/django-base-site#readme",
  "overrides": {
    "stylelint-order": "^7.0.1"
  }
}

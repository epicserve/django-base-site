{
  "name": "django-base-site",
  "description": "Django Base Site",
  "scripts": {
    "dev": "vite --config frontend/config/vite.config.mjs",
    "build": "vite build --config frontend/config/vite.config.mjs",
    "preview": "vite preview --config frontend/config/vite.config.mjs",
    "lint-js": "oxfmt --check ./frontend/ && oxlint ./frontend/",
    "format-js": "oxfmt ./frontend/ && oxlint --fix ./frontend/"
  },
  "devDependencies": {
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "reka-ui": "^2.10.1",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.39",
    "vue-advanced-cropper": "^2.8.9",
    "vue-router": "^5.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/epicserve/django-base-site.git"
  },

#!/usr/bin/env bash
# Installed by `just install_hooks` (also run by `just init`).
# Runs the full lint suite before pushing. Bypass with: git push --no-verify
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Make sure the linter's tooling is reachable (starts web when using Docker).
just _ensure_web

just lint
